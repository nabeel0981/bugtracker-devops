@model BugTracker.Web.Models.Bug
@{
    ViewData["Title"] = $"Edit Bug #{Model.Id}";
    var projects = ViewData["Projects"] as List<BugTracker.Web.Models.Project> ?? new();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/bugs/@Model.Id" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back to Bug</a>
    <span style="font-size:13px;color:#a0aec0;">Editing BUG-@Model.Id</span>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="content-card">
            <div class="content-card-header">
                <h6><i class="bi bi-pencil me-2"></i>Edit Bug Details</h6>
            </div>
            <div class="content-card-body">
                <form method="post" action="/bugs/@Model.Id/edit">
                    <div style="display:grid;gap:20px;">

                        <div>
                            <label class="form-label-custom">Bug Title *</label>
                            <input name="title" value="@Model.Title" class="form-control-custom" placeholder="Describe the bug briefly" required />
                        </div>

                        <div>
                            <label class="form-label-custom">Description</label>
                            <textarea name="description" class="form-control-custom" rows="5" placeholder="Provide steps to reproduce...">@Model.Description</textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">Priority</label>
                                <select name="priority" id="prioritySelect" class="form-control-custom">
                                    <option value="0">Low</option>
                                    <option value="1">Medium</option>
                                    <option value="2">High</option>
                                    <option value="3">Critical</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Status</label>
                                <select name="status" id="statusSelect" class="form-control-custom">
                                    <option value="0">Open</option>
                                    <option value="1">In Progress</option>
                                    <option value="2">Resolved</option>
                                    <option value="3">Closed</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">Reported By</label>
                                <input name="reportedBy" value="@Model.ReportedBy" class="form-control-custom" placeholder="Reporter name" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Assigned To</label>
                                <input name="assignedTo" value="@Model.AssignedTo" class="form-control-custom" placeholder="Developer name" />
                            </div>
                        </div>

                        <div>
                            <label class="form-label-custom">Project</label>
                            <select name="projectId" id="projectSelect" class="form-control-custom">
                                <option value="">— No Project —</option>
                                @foreach (var p in projects)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                        </div>

                        <div class="d-flex gap-2 pt-2">
                            <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Save Changes</button>
                            <a href="/bugs/@Model.Id" class="btn-ghost">Cancel</a>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="content-card">
            <div class="content-card-header">
                <h6><i class="bi bi-info-circle me-2"></i>Bug Info</h6>
            </div>
            <div class="content-card-body">
                <div style="display:grid;gap:14px;">
                    <div>
                        <div style="font-size:11px;font-weight:600;color:#a0aec0;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Bug ID</div>
                        <div style="font-size:14px;color:#2d3748;font-weight:600;">BUG-@Model.Id</div>
                    </div>
                    <div>
                        <div style="font-size:11px;font-weight:600;color:#a0aec0;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Created</div>
                        <div style="font-size:14px;color:#2d3748;">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                    </div>
                    @if (Model.ResolvedAt.HasValue)
                    {
                        <div>
                            <div style="font-size:11px;font-weight:600;color:#a0aec0;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Resolved</div>
                            <div style="font-size:14px;color:#276749;">@Model.ResolvedAt.Value.ToString("MMM dd, yyyy")</div>
                        </div>
                    }
                    <div style="padding:12px;background:#fffaf0;border-radius:8px;border:1px solid #feebc8;">
                        <div style="font-size:12px;color:#c05621;"><i class="bi bi-lightbulb me-1"></i>Tip</div>
                        <div style="font-size:12px;color:#744210;margin-top:4px;">Changing status to Resolved will automatically record the resolution time.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('prioritySelect').value = "@((int)Model.Priority)";
    document.getElementById('statusSelect').value = "@((int)Model.Status)";
    var projectId = "@Model.ProjectId";
    if (projectId) document.getElementById('projectSelect').value = projectId;
</script>
