@{
    ViewData["Title"] = "Report New Bug";
    var projects = ViewData["Projects"] as List<BugTracker.Web.Models.Project> ?? new();
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/bugs" class="btn-ghost"><i class="bi bi-arrow-left"></i> Back to Bugs</a>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="content-card">
            <div class="content-card-header">
                <h6><i class="bi bi-bug me-2"></i>Report New Bug</h6>
            </div>
            <div class="content-card-body">
                <form method="post" action="/bugs/create">
                    <div style="display:grid;gap:20px;">

                        <div>
                            <label class="form-label-custom">Bug Title *</label>
                            <input name="title" class="form-control-custom" placeholder="Describe the bug briefly" required />
                        </div>

                        <div>
                            <label class="form-label-custom">Description</label>
                            <textarea name="description" class="form-control-custom" rows="5"
                                placeholder="Steps to reproduce:&#10;1. Go to...&#10;2. Click on...&#10;&#10;Expected: ...&#10;Actual: ..."></textarea>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">Priority</label>
                                <select name="priority" class="form-control-custom">
                                    <option value="0">🟢 Low</option>
                                    <option value="1" selected>🔵 Medium</option>
                                    <option value="2">🟠 High</option>
                                    <option value="3">🔴 Critical</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Project</label>
                                <select name="projectId" class="form-control-custom">
                                    <option value="">— No Project —</option>
                                    @foreach (var p in projects)
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label-custom">Reported By</label>
                                <input name="reportedBy" class="form-control-custom" placeholder="Your name" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label-custom">Assign To</label>
                                <input name="assignedTo" class="form-control-custom" placeholder="Developer name" />
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-2">
                            <button type="submit" class="btn-primary-custom">
                                <i class="bi bi-bug"></i> Submit Bug Report
                            </button>
                            <a href="/bugs" class="btn-ghost">Cancel</a>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Tips Panel -->
    <div class="col-md-4">
        <div class="content-card">
            <div class="content-card-header">
                <h6><i class="bi bi-lightbulb me-2"></i>Tips for a Good Bug Report</h6>
            </div>
            <div class="content-card-body">
                <div style="display:grid;gap:14px;">
                    <div style="display:flex;gap:10px;align-items:flex-start;">
                        <div style="width:28px;height:28px;background:#fff5f5;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px;">1️⃣</div>
                        <div>
                            <div style="font-size:13px;font-weight:500;color:#1a202c;">Be specific</div>
                            <div style="font-size:12px;color:#718096;margin-top:2px;">Include exact steps to reproduce the issue</div>
                        </div>
                    </div>
                    <div style="display:flex;gap:10px;align-items:flex-start;">
                        <div style="width:28px;height:28px;background:#fffaf0;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px;">2️⃣</div>
                        <div>
                            <div style="font-size:13px;font-weight:500;color:#1a202c;">Set correct priority</div>
                            <div style="font-size:12px;color:#718096;margin-top:2px;">Critical = app breaking, High = major feature broken</div>
                        </div>
                    </div>
                    <div style="display:flex;gap:10px;align-items:flex-start;">
                        <div style="width:28px;height:28px;background:#f0fff4;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px;">3️⃣</div>
                        <div>
                            <div style="font-size:13px;font-weight:500;color:#1a202c;">Assign to the right dev</div>
                            <div style="font-size:12px;color:#718096;margin-top:2px;">Assigned bugs move to In Progress automatically</div>
                        </div>
                    </div>
                    <div style="display:flex;gap:10px;align-items:flex-start;">
                        <div style="width:28px;height:28px;background:#ebf8ff;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px;">4️⃣</div>
                        <div>
                            <div style="font-size:13px;font-weight:500;color:#1a202c;">Link to a project</div>
                            <div style="font-size:12px;color:#718096;margin-top:2px;">Helps track bugs by team or module</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
